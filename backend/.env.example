# Required: Groq API key for LLM calls (get one at https://console.groq.com)
POSTMAIL_GROQ_API_KEY=

# Required for production auth: Supabase JWT secret (Dashboard > Settings > API > JWT Secret)
# Leave commented out for dev mode (uses X-Dev-User-Id header fallback)
# POSTMAIL_SUPABASE_JWT_SECRET=

# Optional: YouTube Data API key for transcript fetching
# POSTMAIL_YOUTUBE_API_KEY=

# Database connection (defaults to local docker-compose DB)
# POSTMAIL_DATABASE_URL=postgresql+asyncpg://postmail:postmail@localhost:5433/postmail

# LLM model (defaults to llama-3.3-70b-versatile)
# POSTMAIL_GROQ_MODEL=llama-3.3-70b-versatile

# Digest cron schedule in UTC (defaults to 06:00)
# POSTMAIL_DIGEST_CRON_HOUR=6
# POSTMAIL_DIGEST_CRON_MINUTE=0

# CORS origins (defaults to http://localhost:3000)
# For production, set to your deployed frontend URL:
# POSTMAIL_CORS_ORIGINS=["https://your-app.vercel.app"]

# Supabase project URL (for JWKS-based auth verification)
# POSTMAIL_SUPABASE_URL=https://your-project.supabase.co
