FROM python:3.12-slim

WORKDIR /app

# Install system deps for building native extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir .

COPY . .


EXPOSE 8000

COPY start.sh .
CMD ["sh", "start.sh"]
